{
  "scripts": {
    "parcel": "parcel",
    "dev": "node clean.js dist && parcel src/index.pug src/**/index.pug",
    "build:parcel": "node clean.js && parcel build --no-cache src/index.pug src/**/index.pug --public-url /EasyTools/ --no-source-maps",
    "build": "node clean.js dist && parcel build --no-cache src/index.pug src/**/index.pug --no-source-maps && firebase deploy"
  },
  "staticFiles": [
    {
      "staticPath": "images",
      "staticOutPath": "images"
    },
    {
      "staticPath": "Ads.txt",
      "staticOutPath": ""
    },
    {
      "staticPath": "robots.txt",
      "staticOutPath": ""
    },
    {
      "staticPath": "sitemap.xml",
      "staticOutPath": ""
    }
  ],
  "dependencies": {
    "firebase": "^12.10.0",
    "html-to-image": "^1.11.13",
    "jquery": "^4.0.0",
    "jspdf": "^4.2.1",
    "vue": "^3.5.28"
  },
  "devDependencies": {
    "@parcel/config-default": "^2.16.4",
    "@parcel/reporter-dev-server": "^2.16.4",
    "@parcel/transformer-pug": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@parcel/transformer-vue": "^2.16.4",
    "@types/jquery": "^4.0.0",
    "parcel": "^2.16.4",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "process": "^0.11.10"
  }
}
